# ==============================================================================
# OpenWrt Configuration: Linksys MX4300 (IPQ807x)
# ==============================================================================
# 1. Copy to build root as `.config`
# 2. Run `make defconfig`
# 3. Run `make menuconfig`
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. TARGET PLATFORM & BUILD OPTIONS
# ------------------------------------------------------------------------------
CONFIG_BUILD_PATENTED=y
CONFIG_DEVEL=y
CONFIG_EXPERIMENTAL=y
CONFIG_TARGET_INIT_PATH="/usr/sbin:/usr/bin:/sbin:/bin:/opt/usr/bin:/opt/bin:/opt/sbin:/opt/usr/sbin"
CONFIG_TARGET_qualcommax=y
CONFIG_TARGET_qualcommax_ipq807x=y
CONFIG_TARGET_qualcommax_ipq807x_DEVICE_linksys_mx4300=y

# ------------------------------------------------------------------------------
# 2. COMPILER & TOOLCHAIN
# ------------------------------------------------------------------------------
CONFIG_BINUTILS_USE_VERSION_2_45=y
CONFIG_GCC_USE_VERSION_15=y
CONFIG_TARGET_OPTIONS=y
CONFIG_TARGET_OPTIMIZATION="-O2 -pipe -mcpu=cortex-a53+crc+crypto"
CONFIG_TOOLCHAINOPTS=y

# Optimization Flags
# CONFIG_GDB is not set
CONFIG_CCACHE=y
CONFIG_GCC_USE_GRAPHITE=y
CONFIG_USE_GC_SECTIONS=y
CONFIG_USE_LTO=y
CONFIG_USE_MKLIBS=y
CONFIG_USE_MOLD=y
CONFIG_ZLIB_OPTIMIZE_SPEED=y
CONFIG_ZSTD_OPTIMIZE_O3=y

# ------------------------------------------------------------------------------
# 3. KERNEL & SECURITY
# ------------------------------------------------------------------------------
# Hardening
# CONFIG_SELINUX is not set
CONFIG_GCC_DEFAULT_PIE=y
CONFIG_KERNEL_CC_STACKPROTECTOR_STRONG=y
CONFIG_PKG_ASLR_PIE_ALL=y
CONFIG_PKG_CC_STACKPROTECTOR_STRONG=y
CONFIG_PKG_FORTIFY_SOURCE_3=y

# Kernel Options
# CONFIG_KERNEL_ARM_PMU is not set
# CONFIG_KERNEL_CGROUPS is not set
# CONFIG_KERNEL_NAMESPACES is not set
CONFIG_KERNEL_PREEMPT_NONE=y
CONFIG_KERNEL_PREEMPT_NONE_BUILD=y
CONFIG_KERNEL_SKB_RECYCLER_PREALLOC=y

# Debugging (Disabled for Performance)
# CONFIG_ATH11K_DEBUGFS_HTT_STATS is not set
# CONFIG_ATH11K_DEBUGFS_STA is not set
# CONFIG_ATH11K_THERMAL is not set
# CONFIG_COLLECT_KERNEL_DEBUG is not set
# CONFIG_KERNEL_DEBUG_FS is not set
# CONFIG_KERNEL_DEBUG_INFO is not set
# CONFIG_KERNEL_DEBUG_KERNEL is not set
# CONFIG_KERNEL_DYNAMIC_DEBUG is not set
# CONFIG_KERNEL_PERF_EVENTS is not set

# ------------------------------------------------------------------------------
# 4. HARDWARE ACCELERATION (Qualcomm NSS)
# ------------------------------------------------------------------------------
# Memory Profile
CONFIG_ATH11K_MEM_PROFILE_1G=y
CONFIG_IPQ_MEM_PROFILE_1024=y
CONFIG_KERNEL_IPQ_MEM_PROFILE=1024
CONFIG_NSS_MEM_PROFILE_HIGH=y

# NSS Support & Firmware
CONFIG_ATH11K_NSS_SUPPORT=y
CONFIG_NSS_FIRMWARE_VERSION_12_5=y
CONFIG_PACKAGE_MAC80211_NSS_SUPPORT=y

# Active NSS Drivers
CONFIG_PACKAGE_kmod-qca-mcs=y
CONFIG_PACKAGE_kmod-qca-nss-dp=y
CONFIG_PACKAGE_kmod-qca-nss-drv-igs=y
CONFIG_PACKAGE_kmod-qca-nss-drv-match=y
CONFIG_PACKAGE_kmod-qca-nss-drv-netlink=y
CONFIG_PACKAGE_kmod-qca-ssdk=y

# Offloading Logic (Enable these for 1Gbps+)
CONFIG_NSS_DRV_IPV4_REASM_ENABLE=y
CONFIG_NSS_DRV_IPV6_ENABLE=y
CONFIG_NSS_DRV_IPV6_REASM_ENABLE=y
CONFIG_NSS_DRV_TLS_ENABLE=y

# ! IMPORTANT: Feeds & Core Drivers (Currently Disabled)
# CONFIG_FEED_nss_packages is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-bridge-mgr is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-eogremgr is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-gre is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-vlan-mgr is not set
# CONFIG_PACKAGE_kmod-qca-nss-ecm is not set

# NSS Crypto (Currently Disabled)
# CONFIG_NSS_DRV_CRYPTO_ENABLE is not set
# CONFIG_PACKAGE_kmod-qca-nss-cfi-cryptoapi is not set
# CONFIG_PACKAGE_kmod-qca-nss-crypto is not set
# CONFIG_PACKAGE_nss-eip-firmware is not set

# ------------------------------------------------------------------------------
# 5. CRYPTOGRAPHY & SSL
# ------------------------------------------------------------------------------
# OpenSSL (Optimized)
# CONFIG_OPENSSL_WITH_ERROR_MESSAGES is not set
CONFIG_LIBCURL_OPENSSL=y
CONFIG_LUA_ECO_OPENSSL=y
CONFIG_OPENSSL_OPTIMIZE_SPEED=y
CONFIG_OPENSSL_WITH_DTLS=y
CONFIG_OPENSSL_WITH_QUIC=y
CONFIG_PACKAGE_apk-openssl=y
CONFIG_PACKAGE_libopenssl=y
CONFIG_PACKAGE_libustream-openssl=y

# mbedTLS (Disabled)
CONFIG_PACKAGE_wpad-basic-mbedtls=n
# CONFIG_LIBCURL_MBEDTLS is not set
# CONFIG_LUA_ECO_MBEDTLS is not set
# CONFIG_PACKAGE_apk-mbedtls is not set
# CONFIG_PACKAGE_libmbedtls is not set
# CONFIG_PACKAGE_libustream-mbedtls is not set

# ------------------------------------------------------------------------------
# 6. NETWORK & VPN
# ------------------------------------------------------------------------------
# Protocols & Shaping
CONFIG_LIBCURL_HTTP3=y
CONFIG_PACKAGE_kmod-tcp-bbr=y

# SQM (Smart Queue Management)
# CONFIG_FEED_sqm_scripts_nss is not set
# CONFIG_PACKAGE_kmod-nss-ifb is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-qdisc is not set
# CONFIG_PACKAGE_luci-app-sqm is not set
# CONFIG_PACKAGE_sqm-scripts-nss is not set

# AmneziaWG
# CONFIG_PACKAGE_amneziawg-go is not set
CONFIG_PACKAGE_amneziawg-tools=y
CONFIG_PACKAGE_kmod-amneziawg=y
CONFIG_PACKAGE_luci-proto-amneziawg=y

# Software Crypto Fallbacks (Modules)
# CONFIG_PACKAGE_kmod-crypto-chacha20poly1305 is not set
# CONFIG_PACKAGE_kmod-crypto-lib-chacha20 is not set
# CONFIG_PACKAGE_kmod-crypto-lib-chacha20poly1305 is not set
# CONFIG_PACKAGE_kmod-cryptodev is not set

# OpenVPN Options (Reference)
# CONFIG_OPENVPN_openssl_ENABLE_DCO is not set
# CONFIG_PACKAGE_kmod-ovpn-dco-v2 is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-ovpn-link is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-ovpn-mgr is not set
# CONFIG_PACKAGE_kmod-qca-nss-drv-qvpn is not set
# CONFIG_PACKAGE_openvpn-easy-rsa is not set
# CONFIG_PACKAGE_openvpn-openssl is not set

# DHCP Engine Swap
# CONFIG_PACKAGE_odhcpd-ipv6only is not set
CONFIG_PACKAGE_odhcpd=y

# ------------------------------------------------------------------------------
# 7. PACKAGES & UTILITIES
# ------------------------------------------------------------------------------
# Networking Tools
CONFIG_LIBCURL_OPENSSL=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_iperf3=y
CONFIG_PACKAGE_qrencode=y
CONFIG_PACKAGE_rsync=y
CONFIG_PACKAGE_speedtest-go=y
CONFIG_PACKAGE_tcpdump=y
CONFIG_PACKAGE_wpad-openssl=y

# DNS
# CONFIG_PACKAGE_smartdns-ui is not set
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_smartdns=y

# SSH & Access
# CONFIG_PACKAGE_dropbear is not set
CONFIG_PACKAGE_openssh-server=y
CONFIG_PACKAGE_openssh-sftp-server=y

# System Utils
# CONFIG_HTOP_LMSENSORS is not set
CONFIG_PACKAGE_htop=y

# Filesystems
# CONFIG_PACKAGE_kmod-fs-f2fs is not set
# CONFIG_PACKAGE_kmod-fs-ntfs3 is not set
CONFIG_PACKAGE_kmod-fs-vfat=y
CONFIG_PACKAGE_kmod-usb-storage=y

# ------------------------------------------------------------------------------
# 8. LUCI (WEB UI)
# ------------------------------------------------------------------------------
# CONFIG_PACKAGE_ip-tiny is not set
# CONFIG_PACKAGE_dnsmasq is not set
# CONFIG_PACKAGE_luci-mod-status-nss is not set
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-firewall=y
CONFIG_PACKAGE_luci-app-package-manager=y
CONFIG_PACKAGE_luci-app-pbr=y
CONFIG_PACKAGE_luci-proto-wireguard=y
CONFIG_PACKAGE_luci-ssl-openssl=y

# Disabled LuCI Apps
# CONFIG_PACKAGE_attendedsysupgrade-common is not set
# CONFIG_PACKAGE_luci-app-advanced-reboot is not set
# CONFIG_PACKAGE_luci-app-attendedsysupgrade is not set
